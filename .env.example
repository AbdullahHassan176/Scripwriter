YOUTUBE_API_KEY=your_api_key_here

# Browser to pull YouTube cookies from (bypasses 429 rate limits).
# Options: chrome, firefox, edge, brave  — set to 'none' to disable.
YTCHAN_COOKIES_BROWSER=chrome

# Optional: proxy for transcript fetching (yt-dlp honours this)
# YTCHAN_PROXY=http://127.0.0.1:7890

# Optional: override default data/logs directories
# DATA_DIR=data
# LOGS_DIR=logs
